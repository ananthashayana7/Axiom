+                                                        <span className={cn("h-1.5 w-1.5 rounded-full", status.dot)} />
+                                                        <span className={status.color}>{status.label}</span>
+                                                    </span>
+                                                </td>
+                                            </tr>
+                                        );
+                                    })}
