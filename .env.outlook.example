# Outlook SMTP template for Axiom support emails
# Copy this file to `.env` in project root and fill values.
# Docker Compose reads `.env` automatically.

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=axiom-no_reply@outlook.com
SMTP_PASS=REPLACE_WITH_MAILBOX_PASSWORD_OR_APP_PASSWORD
SMTP_SECURE=false
SMTP_FROM=axiom-no_reply@outlook.com

# Optional: ensure auth callbacks and links resolve correctly
# NEXTAUTH_URL=http://localhost:3000
