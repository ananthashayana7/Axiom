# Production environment template for Azure App Service / Container Apps
NODE_ENV=production

# App URL and auth
NEXTAUTH_URL=https://your-app-name.azurewebsites.net
AXIOM_ALLOWED_ORIGINS=https://your-app-name.azurewebsites.net
NEXTAUTH_SECRET=replace-with-strong-random-secret
AUTH_SECRET=replace-with-strong-random-secret

# Database and cache
DATABASE_URL=postgres://username:password@your-postgres-host:5432/procurement_db?sslmode=require
PGSSLMODE=require
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000
REDIS_URL=redis://:password@your-redis-host:6379
RATE_LIMIT_NAMESPACE=axiom-prod
RATE_LIMIT_READ_PER_MINUTE=300
RATE_LIMIT_WRITE_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5

# Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=axiom-docs

# Scheduler security
CRON_SECRET=replace-with-strong-random-secret

# Feature safety
ALLOW_DEMO_BYPASS=false
